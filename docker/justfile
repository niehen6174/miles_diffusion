SGLANG_IMAGE_TAG_CU13 := "v0.5.14-cu130"

# The recipes below take a `variant` arg (default `cu12`):
#   cu12 — original behaviour: cu129 base, reads docker/version.txt, owns `latest`.
#   cu13 — cu130 base via SGLANG_IMAGE_TAG, reads docker/version-cu13.txt,
#          `-cu13` tag postfix, and does NOT move `latest` (still experimental).

release-primary variant="cu12":
    #!/bin/bash
    if [ "{{variant}}" = "cu13" ]; then
        ARG_TAG_POSTFIX="-cu13" ARG_BUILD_EXTRA_ARGS="--build-arg SGLANG_IMAGE_TAG={{SGLANG_IMAGE_TAG_CU13}}" ARG_VERSION_FILE="docker/version-cu13.txt" just _release-raw
    else
        ARG_TAG_POSTFIX="" ARG_BUILD_EXTRA_ARGS="" just _release-raw
    fi

_release-raw:
    #!/bin/bash
    set -euxo pipefail
    cd ..

    VERSION="$(cat ${ARG_VERSION_FILE:-docker/version.txt} | tr -d '\n')"
    IMAGE_TAG=${VERSION}${ARG_TAG_POSTFIX}

    docker build -f docker/Dockerfile . --build-arg HTTP_PROXY="$http_proxy" --build-arg HTTPS_PROXY="$https_proxy" --build-arg NO_PROXY="localhost,127.0.0.1" $ARG_BUILD_EXTRA_ARGS -t radixark/miles-diffusion:$IMAGE_TAG
    docker push radixark/miles-diffusion:$IMAGE_TAG

    if [ -z "${ARG_TAG_POSTFIX}" ]; then
        docker tag radixark/miles-diffusion:$IMAGE_TAG radixark/miles-diffusion:latest
        docker push radixark/miles-diffusion:latest
    fi

debug variant="cu12":
    #!/bin/bash
    set -euxo pipefail
    cd ..

    if [ "{{variant}}" = "cu13" ]; then
        EXTRA="--build-arg SGLANG_IMAGE_TAG={{SGLANG_IMAGE_TAG_CU13}}"; VFILE="docker/version-cu13.txt"; POSTFIX="-cu13"
    else
        EXTRA=""; VFILE="docker/version.txt"; POSTFIX=""
    fi
    VERSION="$(cat $VFILE | tr -d '\n')"
    IMAGE_TAG=${VERSION}${POSTFIX}

    docker build -f docker/Dockerfile . $EXTRA --build-arg HTTP_PROXY="$http_proxy" --build-arg HTTPS_PROXY="$https_proxy" --build-arg NO_PROXY="localhost,127.0.0.1" -t radixark/miles-diffusion-test:$IMAGE_TAG
    docker push radixark/miles-diffusion-test:$IMAGE_TAG

    if [ -z "$POSTFIX" ]; then
        docker tag radixark/miles-diffusion-test:$IMAGE_TAG radixark/miles-diffusion-test:latest
        docker push radixark/miles-diffusion-test:latest
    fi

# Local build only (no push), tag suffixed with -local. Not present in the
# radixark/miles justfile; kept for diffusion local iteration.
build-local variant="cu12":
    #!/bin/bash
    set -euxo pipefail
    cd ..

    if [ "{{variant}}" = "cu13" ]; then
        EXTRA="--build-arg SGLANG_IMAGE_TAG={{SGLANG_IMAGE_TAG_CU13}}"; VFILE="docker/version-cu13.txt"; POSTFIX="-cu13"
    else
        EXTRA=""; VFILE="docker/version.txt"; POSTFIX=""
    fi
    VERSION="$(cat $VFILE | tr -d '\n')"
    IMAGE_TAG="${VERSION}${POSTFIX}-local"

    docker build -f docker/Dockerfile . $EXTRA --build-arg HTTP_PROXY="$http_proxy" --build-arg HTTPS_PROXY="$https_proxy" --build-arg NO_PROXY="localhost,127.0.0.1" -t radixark/miles-diffusion:$IMAGE_TAG
